{% extends "layout.njk" %}
{% block title %}Inicio - Filomena Arte y Diseño{% endblock %}
{% block content %}
    <div style="text-align: center; margin-top: 2rem;">
        <img
            src="/images/IsotipoFilomenav2-Para-la-pagina.svg"
            alt="Filomena Arte y Diseño"
            style="width: 100%; max-width: 400px; height: auto; margin-bottom: 1.5rem; filter: drop-shadow(0 4px 6px
                rgba(0,0,0,0.1));">
        <p style="color: var(--text-light); font-size: 1.2rem; max-width: 700px; margin: 0 auto; line-height: 1.6; font-weight:
                500;">
            El arte de la encuadernación artesanal. Explora nuestros productos, talleres y conoce la historia detrás de cada detalle
            cosido a mano.
        </p>
        <div
            style="margin-top: 3rem; display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap;">
            <!-- Card de ejemplo -->
            <div style="background: var(--surface); padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-md); border: 1px solid
                    var(--glass-border); max-width: 300px;">
                <h3 style="color: var(--accent-color); margin-bottom: 1rem;">Catálogo</h3>
                <p style="color: var(--text-light); font-size: 0.95rem;">Descubre la nueva colección de libretas de autor.</p>
            </div>
            <div style="background: var(--surface); padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-md); border: 1px solid
                    var(--glass-border); max-width: 300px;">
                <h3 style="color: var(--accent-color); margin-bottom: 1rem;">Talleres</h3>
                <p style="color: var(--text-light); font-size: 0.95rem;">Aprende las técnicas centenarias de encuadernación copta.</p>
            </div>
        </div>
    </div>
{% endblock %}