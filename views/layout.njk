<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            {% block title %}Filomena Arte y Diseño{% endblock %}
        </title>
        <!-- Fuentes Google -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"> <!-- Favicon -->
        <link
        rel="icon" type="image/png" href="/images/favicon.png"> <!-- CSS Principal -->
        <link
        rel="stylesheet" href="/css/styles.css"> <!-- Quill Editor CSS (jsDelivr CDN) -->
        <link href="https://cdn.jsdelivr.net/npm/quill@1.3.6/dist/quill.snow.css" rel="stylesheet">
    </head>
    <body>
        <!-- Barra de Navegación -->
        <nav class="navbar" id="main-nav">
            <div class="nav-logo">
                <a href="/">
                    <img src="/images/logoFilo.svg" alt="Logo Filomena" id="navbar-logo">
                </a>
            </div>
            <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menú">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>
            <div class="nav-links" id="nav-links">
                <a href="/">Inicio</a>
                <a href="/catalogo">Catálogo</a>
                <a href="/eventos">Eventos</a>
                <a href="/blog">Blog</a>
                <a href="/contacto">Contacto</a>
                <!-- Carrito de Compras -->
                <a href="/carrito" class="cart-link" title="Ver mi carrito">
                    <span style="font-size: 1.2rem;">🛒</span>
                    <span id="cart-count" style="display: none;">0</span>
                </a>
                <a href="/admin" id="nav-admin-link" style="display: none;">Admin</a>
                <!-- Los siguientes botones se inyectarán/modificarán desde auth.js -->
                <a href="/login" id="nav-login-btn">Login</a>
                <div class="nav-user-menu" id="nav-user-menu" style="display: none;">
                    <span class="nav-user-name" id="nav-user-name">Usuario</span>
                    <div class="nav-user-dropdown">
                        <a href="/perfil">Mi Perfil</a>
                        <a href="#" id="nav-logout-btn">Desloguearse</a>
                    </div>
                </div>
            </div>
        </nav>
        <!-- Contenido dinámico -->
        <main class="container"> {% block content %}{% endblock %}
            </main>
            <!-- Footer -->
            <footer style="position: relative; background: var(--surface); padding: 2rem; border-top: 1px solid var(--glass-border);
                    margin-top: 3rem; overflow: hidden;">
                <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: url('/images/logoFilo.svg');
                    background-size: 60px; background-repeat: repeat; opacity: 0.30; z-index: 0;"></div>
                <div style="position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 1rem;
                        margin-bottom: 2rem;">
                    <div>
                        <p style="color: var(--text-light); text-align: center;">&copy; 2026 Filomena Arte y Diseño. Todos los derechos
                            reservados.</p>
                        <p style="color: var(--text-light); text-align: center;">
                            <a href="/contacto" style="color: var(--text-light); text-decoration: underline; ">Contacto</a>
                        </p>
                    </div>
                </div>
                <div
                    id="dibujito"
                    style="position: relative; z-index: 1; background: #000; padding: 1.5rem 2rem; border-radius: 12px; box-shadow:
                        var(--shadow-md); border: 1px solid var(--glass-border); width: 100%; max-width: 340px; text-align: center; box-sizing:
                        border-box; align-self: center; margin: 0 auto;">
                    <p>Arte ASCII de esta versión de la página</p>
                    <pre id="ascii-canvas" style= "font-family: monospace; font-size: clamp(9px, 2vw, 13px); line-height: 1.35;
                    color: #00ff0d;  white-space: pre; display: block; overflow: hidden;"></pre>
                </div>
            </footer>
            <!-- Scripts -->
            <script src="https://cdn.jsdelivr.net/npm/quill@1.3.6/dist/quill.js"></script>
            <script src="/js/navbar.js"></script>
            <script src="/js/auth.js"></script>
            <script src="/js/cart.js"></script>
            <script src="/js/animacion.js"></script>
        </body>
    </html>