{% extends "layout.njk" %}

{% block title %}Eventos - Filomena Arte y Diseño{% endblock %}

{% block content %}
<div style="margin-top: 2rem;">
    <h1 style="color: var(--primary-color); font-size: 2.5rem; text-align: center; margin-bottom: 2.5rem;">Próximos Eventos</h1>

    {% if eventos.length == 0 %}
        <p style="text-align: center; color: var(--text-light); font-size: 1.1rem;">Por el momento no hay eventos programados. ¡Vuelve pronto!</p>
    {% else %}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem;">
            {% for evento in eventos %}
                <div style="background: var(--surface); border: 1px solid var(--glass-border); border-radius: 16px; padding: 2rem; box-shadow: var(--shadow-md); backdrop-filter: blur(10px); transition: transform 0.3s ease;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <span style="background: var(--accent-color); color: white; padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase;">
                            {{ evento.tipo }}
                        </span>
                        <span style="color: var(--text-light); font-size: 0.9rem; font-weight: 500;">
                            Organizado por: {{ evento.creador.nombre }} {{ evento.creador.apellido }}
                        </span>
                    </div>

                    <h2 style="color: var(--primary-color); font-size: 1.6rem; margin-bottom: 1rem;">{{ evento.tipo }} en {{ evento.lugar }}</h2>
                    
                    <div style="display: flex; flex-direction: column; gap: 0.8rem; color: var(--text-main);">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            <span>{{ evento.fecha_hora | date('DD/MM/YYYY') if evento.fecha_hora else 'Fecha no disponible' }}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            <span>{{ evento.fecha_hora | date('HH:mm') if evento.fecha_hora else 'Hora no disponible' }} hs</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                            <span>{{ evento.lugar }}</span>
                        </div>
                    </div>

                    {% if evento.descripcion %}
                    <p style="margin-top: 1.5rem; color: var(--text-main); line-height: 1.5; font-style: italic; background: rgba(0,0,0,0.02); padding: 1rem; border-radius: 8px; border-left: 3px solid var(--accent-color);">
                        {{ evento.descripcion }}
                    </p>
                    {% endif %}

                    <div style="margin-top: 2rem;">
                        <a href="https://www.google.com/maps/search/?api=1&query={{ evento.lugar | urlencode }}" target="_blank" class="btn-primary" style="display: inline-block; text-align: center; text-decoration: none; padding: 0.8rem 1.5rem;">Ver en Google Maps</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
