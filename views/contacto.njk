{% extends "layout.njk" %}

{% block title %}Contacto - Filomena Arte y Diseño{% endblock %}

{% block content %}
<div style="max-width: 1000px; margin: 2rem auto; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
    <!-- Columna Izquierda: Info de Contacto -->
    <section style="background: var(--surface); border: 1px solid var(--glass-border); border-radius: 16px; padding: 2.5rem; box-shadow: var(--shadow-md); backdrop-filter: blur(10px);">
        <h1 style="color: var(--primary-color); font-size: 2.2rem; margin-bottom: 2rem;">Contáctanos</h1>
        <p style="color: var(--text-main); line-height: 1.6; margin-bottom: 2rem;">
            ¿Tienes alguna duda sobre nuestros productos o talleres? ¡Estamos aquí para ayudarte! 
            Puedes dejarnos un mensaje en el muro o contactarnos por nuestros canales oficiales.
        </p>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="background: var(--accent-color); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.28-2.28a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                </div>
                <span style="color: var(--text-main); font-weight: 500;">+54 9 11 1234-5678</span>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="background: var(--accent-color); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <span style="color: var(--text-main); font-weight: 500;">info@filomenadiseno.com.ar</span>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="background: var(--accent-color); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </div>
                <span style="color: var(--text-main); font-weight: 500;">/FilomenaDiseno</span>
            </div>
        </div>

        <div style="margin-top: 3rem;">
             <h3 style="color: var(--primary-color); margin-bottom: 1rem;">Deja tu mensaje en el muro</h3>
             <form id="contact-wall-form" style="display: flex; flex-direction: column; gap: 1rem;">
                <div id="guest-fields" style="display: flex; flex-direction: column; gap: 1rem;">
                    <input type="text" id="contact-nombre" placeholder="Tu nombre" required style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                    <input type="email" id="contact-email" placeholder="Tu email" required style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                </div>
                <textarea id="contact-mensaje" placeholder="¿Qué quieres decirnos?" required style="width: 100%; padding: 1rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5); min-height: 120px; font-family: inherit; resize: vertical;"></textarea>
                <button type="submit" class="btn-primary" style="width: 100%;">Publicar Mensaje</button>
             </form>
        </div>
    </section>

    <!-- Columna Derecha: Muro de Mensajes -->
    <section>
        <h2 style="color: var(--primary-color); font-size: 2rem; margin-bottom: 2rem; text-align: center;">Muro Público</h2>
        
        <div id="messages-wall" style="display: flex; flex-direction: column; gap: 1.5rem; max-height: 800px; overflow-y: auto; padding-right: 10px;">
            {% if mensajes.length == 0 %}
                <p style="text-align: center; color: var(--text-light);">El muro está vacío. ¡Sé el primero en escribir!</p>
            {% else %}
                {% for msg in mensajes %}
                    <div style="background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: var(--shadow-sm); border-left: 5px solid var(--accent-color); position: relative;">
                        <div style="font-weight: 700; color: var(--primary-color); margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
                            <span>{{ msg.nombre }} {% if msg.usuario %} <small style="color: var(--accent-color); font-weight: normal;">(@{{ msg.usuario.nombreUsuario }})</small> {% endif %}</span>
                            <span style="font-weight: 400; font-size: 0.8rem; color: var(--text-light);">{{ msg.createdAt | date('DD/MM/YYYY') }}</span>
                        </div>
                        <p style="margin: 0; color: var(--text-main); line-height: 1.4;">{{ msg.mensaje }}</p>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
