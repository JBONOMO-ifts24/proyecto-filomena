{% extends "layout.njk" %}

{% block title %}Contacto - Filomena Arte y Diseño{% endblock %}

{% block content %}
<div style="max-width: 1000px; margin: 2rem auto; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;">
    <!-- Columna Izquierda: Info de Contacto -->
    <section
        style="background: var(--surface); border: 1px solid var(--glass-border); border-radius: 16px; padding: 2.5rem; box-shadow: var(--shadow-md); backdrop-filter: blur(10px);">
        <h1 style="color: var(--primary-color); font-size: 2.2rem; margin-bottom: 2rem;">Contáctanos</h1>
        <p style="color: var(--text-main); line-height: 1.6; margin-bottom: 2rem;">
            ¿Tienes alguna duda sobre nuestros productos o talleres? ¡Estamos aquí para ayudarte!
            Puedes dejarnos un mensaje en el muro o contactarnos por nuestros canales oficiales.
        </p>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div
                    style="background: var(--accent-color); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
                    </svg>
                </div>
                <span style="color: var(--text-main); font-weight: 500;"><a
                        href="https://wa.me/5491176080024?text=Hola!%20Me%20comunico%20desde%20tu%20web"
                        target="_blank">
                        WhatsApp
                    </a></span>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div
                    style="background: var(--accent-color); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.245 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.245-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.245-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.245 3.608-1.308 1.266-.058 1.646-.07 4.85-.07M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.981 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                    </svg>
                </div>
                <span style="color: var(--text-main); font-weight: 500;"><a
                        href="https://www.instagram.com/filomena.arteydiseno/#" target="_blank">Instagram</a></span>
            </div>
        </div>

        <div style="margin-top: 3rem;">
            <h3 style="color: var(--primary-color); margin-bottom: 1rem;">Deja tu mensaje en el muro</h3>
            <form id="contact-wall-form" style="display: flex; flex-direction: column; gap: 1rem;">
                <div id="guest-fields" style="display: flex; flex-direction: column; gap: 1rem;">
                    <input type="text" id="contact-nombre" placeholder="Tu nombre" required
                        style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                    <input type="email" id="contact-email" placeholder="Tu email" required
                        style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5);">
                </div>
                <textarea id="contact-mensaje" placeholder="¿Qué quieres decirnos?" required
                    style="width: 100%; padding: 1rem; border-radius: 8px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.5); min-height: 120px; font-family: inherit; resize: vertical;"></textarea>
                <button type="submit" class="btn-primary" style="width: 100%;">Publicar Mensaje</button>
            </form>
        </div>
    </section>

    <!-- Columna Derecha: Muro de Mensajes -->
    <section>
        <h2 style="color: var(--primary-color); font-size: 2rem; margin-bottom: 2rem; text-align: center;">Muro Público
        </h2>

        <div id="messages-wall"
            style="display: flex; flex-direction: column; gap: 1.5rem; max-height: 800px; overflow-y: auto; padding-right: 10px;">
            {% if mensajes.length == 0 %}
            <p style="text-align: center; color: var(--text-light);">El muro está vacío. ¡Sé el primero en escribir!</p>
            {% else %}
            {% for msg in mensajes %}
            <div
                style="background: #fff; border-radius: 12px; padding: 1.5rem; box-shadow: var(--shadow-sm); border-left: 5px solid var(--accent-color); position: relative;">
                <div class="message-actions" data-mensaje-id="{{ msg.id }}" data-usuario-id="{{ msg.usuarioId }}"
                    style="display: none; position: absolute; top: 1rem; right: 1rem;">
                    <button class="btn-message-delete"
                        style="background: none; border: none; color: #d32f2f; cursor: pointer; padding: 0.2rem;"
                        title="Eliminar mensaje">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                            viewBox="0 0 24 24">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                            </path>
                        </svg>
                    </button>
                </div>
                <div
                    style="font-weight: 700; color: var(--primary-color); margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
                    <span>{{ msg.nombre }} {% if msg.usuario %} <small
                            style="color: var(--accent-color); font-weight: normal;">(@{{ msg.usuario.nombreUsuario
                            }})</small> {% endif %}</span>
                    <span style="font-weight: 400; font-size: 0.8rem; color: var(--text-light);">{{ msg.createdAt |
                        date('DD/MM/YYYY') }}</span>
                </div>
                <p style="margin: 0; color: var(--text-main); line-height: 1.4;">{{ msg.mensaje }}</p>
            </div>
            {% endfor %}
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}