{% extends "layout.njk" %}

{% block title %}Panel de Administración - Filomena Arte y Diseño{% endblock %}

{% block content %}
<div id="admin-dashboard" class="container" style="display: none; margin-top: 2rem;">
    <h1 style="color: var(--primary-color); text-align: center; margin-bottom: 2rem;">Panel de Control Administrativo</h1>

    <!-- Tabs Navigation -->
    <div style="display: flex; gap: 1rem; border-bottom: 1px solid var(--glass-border); margin-bottom: 2rem; overflow-x: auto; padding-bottom: 0.5rem;">
        <button class="tab-btn active" data-tab="productos" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Productos</button>
        <button class="tab-btn" data-tab="modelos" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Modelos</button>
        <button class="tab-btn" data-tab="tipos" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Tipos</button>
        <button class="tab-btn" data-tab="eventos" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Eventos</button>
        <button class="tab-btn" data-tab="posteos" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Posteos</button>
        <button class="tab-btn" data-tab="usuarios" style="background: none; border: none; padding: 0.8rem 1.5rem; color: var(--text-main); font-weight: 600; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s ease;">Usuarios</button>
    </div>

    <!-- Tab Sections -->
    <div id="productos-section" class="tab-content active">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Productos</h2>
            <button class="btn-primary" onclick="openModal('producto')">+ Nuevo Producto</button>
        </div>

        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Código</th>
                        <th style="padding: 1rem; text-align: left;">Nombre</th>
                        <th style="padding: 1rem; text-align: left;">Stock</th>
                        <th style="padding: 1rem; text-align: left;">Precio</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="productos-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>

        <div style="background: var(--surface); border: 1px solid var(--glass-border); border-radius: 12px; padding: 1.5rem; margin-top: 2rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h3 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.1rem;">Gestión Masiva de Stock</h3>
                <p style="color: var(--text-light); margin: 0; font-size: 0.9rem;">Descarga la planilla actual, modifícala y súbela para actualizar el stock rápidamente.</p>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <button class="btn-primary" onclick="descargarStock()" style="background-color: #2e7d32;"><svg style="vertical-align: middle; margin-right: 5px;" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/></svg> Descargar XLS</button>
                <form id="form-importar-stock" style="display: flex; gap: 0.5rem; align-items: center;">
                    <input type="file" id="archivo-stock" accept=".xlsx" style="font-size: 0.85rem;" required>
                    <button type="submit" class="btn-primary" style="background-color: #0277bd;"><svg style="vertical-align: middle; margin-right: 5px;" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/><path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/></svg> Subir y Actualizar</button>
                </form>
            </div>
        </div>
    </div>

    <div id="modelos-section" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Modelos de Producto</h2>
            <button class="btn-primary" onclick="openModal('modeloproducto')">+ Nuevo Modelo</button>
        </div>
        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Código</th>
                        <th style="padding: 1rem; text-align: left;">Nombre</th>
                        <th style="padding: 1rem; text-align: left;">Tipo</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="modelos-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>
    </div>

    <div id="tipos-section" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Tipos de Producto</h2>
            <button class="btn-primary" onclick="openModal('tipoproducto')">+ Nuevo Tipo</button>
        </div>
        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Nombre</th>
                        <th style="padding: 1rem; text-align: left;">Descripción</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tipos-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>
    </div>

    <div id="eventos-section" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Eventos</h2>
            <button class="btn-primary" onclick="openModal('evento')">+ Nuevo Evento</button>
        </div>
        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Tipo</th>
                        <th style="padding: 1rem; text-align: left;">Fecha</th>
                        <th style="padding: 1rem; text-align: left;">Lugar</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="eventos-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>
    </div>

    <div id="posteos-section" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Posteos</h2>
            <button class="btn-primary" onclick="openModal('posteo')">+ Nuevo Posteo</button>
        </div>
        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Título</th>
                        <th style="padding: 1rem; text-align: left;">Fecha</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="posteos-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>
    </div>

    <div id="usuarios-section" class="tab-content" style="display: none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="color: var(--accent-color);">Gestión de Usuarios</h2>
            <button class="btn-primary" onclick="openModal('usuario')">+ Nuevo Usuario </button>
        </div>
        <div class="table-container" style="background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow-sm);">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: rgba(0,0,0,0.05);">
                    <tr>
                        <th style="padding: 1rem; text-align: left;">Username</th>
                        <th style="padding: 1rem; text-align: left;">Email</th>
                        <th style="padding: 1rem; text-align: left;">Rol</th>
                        <th style="padding: 1rem; text-align: left;">Estado</th>
                        <th style="padding: 1rem; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="usuarios-table-body">
                    <!-- Dynamic Content -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Overlay (Generic) -->
<div id="admin-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; backdrop-filter: blur(5px);">
    <div style="background: #fff; width: 90%; max-width: 600px; padding: 2.5rem; border-radius: 16px; box-shadow: var(--shadow-lg); position: relative;">
        <button onclick="closeModal()" style="position: absolute; top: 1rem; right: 1.5rem; background: none; border: none; font-size: 2rem; cursor: pointer; color: var(--text-light);">&times;</button>
        <h2 id="modal-title" style="color: var(--primary-color); margin-bottom: 1.5rem;">Formulario</h2>
        <form id="admin-form" style="display: flex; flex-direction: column; gap: 1rem;">
            <div id="form-fields">
                <!-- Dynamic Fields -->
            </div>
            <button type="submit" class="btn-primary" style="margin-top: 1rem;">Guardar Cambios</button>
        </form>
    </div>
</div>

<div id="unauthorized-message" style="display: none; text-align: center; margin-top: 5rem;">
    <h1 style="color: var(--primary-color);">Acceso Restringido</h1>
    <p style="color: var(--text-light);">No tienes permisos para acceder a esta sección.</p>
    <a href="/" class="btn-primary" style="display: inline-block; margin-top: 1rem;">Volver al Inicio</a>
</div>

<script src="/js/admin.js"></script>

<style>
    .tab-btn.active {
        color: var(--accent-color) !important;
        border-bottom-color: var(--accent-color) !important;
    }
    th, td { border-bottom: 1px solid var(--glass-border); }
    tr:hover { background: rgba(191, 67, 216, 0.05); }
    .btn-action { padding: 0.4rem 0.8rem; border-radius: 6px; cursor: pointer; font-size: 0.85rem; border: none; transition: 0.3s; }
    .btn-edit { background: #e3f2fd; color: #1976d2; margin-right: 0.5rem; }
    .btn-delete { background: #ffebee; color: #d32f2f; }
    .admin-input {
        width: 100%;
        padding: 0.8rem;
        margin-bottom: 0.5rem;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: rgba(255, 255, 255, 0.7);
        font-family: inherit;
        font-size: 0.95rem;
    }
    .admin-input:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 3px rgba(191, 67, 216, 0.1);
    }
</style>
{% endblock %}
