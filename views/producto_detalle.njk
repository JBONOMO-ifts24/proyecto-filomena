{% extends "layout.njk" %}

{% block title %}{{ producto.nombre }} - Detalle Producto{% endblock %}

{% block content %}
<div style="margin-top: 2rem; max-width: 1000px; margin-left: auto; margin-right: auto;">
    <a href="/catalogo" style="text-decoration: none; color: var(--accent-color); font-weight: 600; display: inline-flex; align-items: center; margin-bottom: 2rem;">
        <span style="margin-right: 5px;">←</span> Volver al catálogo
    </a>

    <div class="grid-2-cols" style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; background: var(--surface); padding: 2.5rem; border-radius: 20px; border: 1px solid var(--glass-border); box-shadow: var(--shadow-md);">
        
        <!-- Galería de Imágenes -->
        <div>
            {% set imagenesOrdenadas = [] %}
            {% for img in producto.imagenes %}
                {% if img.es_principal %}
                    {% set imagenesOrdenadas = (imagenesOrdenadas.push(img), imagenesOrdenadas) %}
                {% endif %}
            {% endfor %}
            {% for img in producto.imagenes %}
                {% if not img.es_principal %}
                    {% set imagenesOrdenadas = (imagenesOrdenadas.push(img), imagenesOrdenadas) %}
                {% endif %}
            {% endfor %}

            <div style="height: 400px; background: #f9f9f9; border-radius: 12px; overflow: hidden; margin-bottom: 1rem; border: 1px solid #eee;">
                {% if imagenesOrdenadas.length > 0 %}
                    <img id="main-product-image" src="{{ imagenesOrdenadas[0].url }}" alt="{{ producto.nombre }}" style="width: 100%; height: 100%; object-fit: contain;">
                {% else %}
                    <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #999;">Sin imagen</div>
                {% endif %}
            </div>

            {% if imagenesOrdenadas.length > 1 %}
                <div style="display: flex; gap: 10px;">
                    {% for img in imagenesOrdenadas %}
                        <img src="{{ img.url }}" alt="Vista {{ loop.index }}" 
                             style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; cursor: pointer; border: 2px solid {{ 'var(--accent-color)' if loop.first else 'transparent' }};"
                             onclick="showImage('{{ img.url }}', this)">
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <!-- Información del Producto -->
        <div style="display: flex; flex-direction: column;">
            <div style="margin-bottom: 1.5rem;">
                <p style="color: var(--accent-color); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; margin-bottom: 0.5rem;">
                    {{ producto.modelo.tipo_producto.nombre }} / {{ producto.modelo.nombre }}
                </p>
                <h1 style="color: var(--primary-color); font-size: 2.5rem; margin: 0; line-height: 1.2;">{{ producto.nombre }}</h1>
                <p style="color: var(--text-light); font-size: 0.95rem; margin-top: 0.5rem;">Código: {{ producto.codigo }}</p>
            </div>

            <div style="margin-bottom: 2rem;">
                <h3 style="color: var(--primary-color); font-size: 1.1rem; margin-bottom: 0.8rem;">Descripción</h3>
                <div style="color: var(--text-main); line-height: 1.6; font-size: 1.05rem; background: rgba(255,255,255,0.3); padding: 1rem; border-radius: 8px; border: 1px solid var(--glass-border);">
                    {% if producto.descripcion %}
                        {{ producto.descripcion | safe }}
                    {% else %}
                        <span style="color: var(--text-light); font-style: italic;">Sin descripción detallada disponible.</span>
                    {% endif %}
                </div>
            </div>

            <div style="margin-top: auto; padding-top: 2rem; border-top: 1px solid var(--glass-border); display: flex; flex-direction: column; gap: 1rem;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        {% if producto.precio !== null and producto.precio !== undefined %}
                            <p style="font-size: 0.9rem; color: var(--text-light); margin: 0;">Precio</p>
                            <p style="font-size: 2rem; color: var(--primary-color); font-weight: 700; margin: 0;">{{ producto.precio | pesosAR }}</p>
                            <p style="font-size: 0.8rem; color: var(--text-light); margin: 0.3rem 0 0 0; font-style: italic;">Pesos Argentinos (ARS)</p>
                        {% else %}
                            <p style="font-size: 1.1rem; color: var(--text-light); margin: 0;">Consultar precio</p>
                        {% endif %}
                    </div>
                    
                    <div style="text-align: right;">
                        <span style="display: inline-block; padding: 6px 15px; border-radius: 20px; font-weight: 600; font-size: 0.9rem; 
                            background: {{ '#e8f5e9' if producto.cantidad > 0 else '#ffebee' }}; 
                            color: {{ '#2e7d32' if producto.cantidad > 0 else '#c62828' }};">
                            {% if producto.cantidad > 0 %}
                                En Stock: {{ producto.cantidad }}
                            {% else %}
                                Sin Stock / Agotado
                            {% endif %}
                        </span>
                    </div>
                </div>

                {% if producto.precio !== null and producto.precio !== undefined and producto.cantidad > 0 %}
                <div style="display: flex; gap: 1rem; align-items: center; margin-top: 1rem;">
                    <div style="display: flex; align-items: center; border: 1px solid #ccc; border-radius: 8px; overflow: hidden; height: 45px;">
                        <button onclick="changeDetailQty(-1)" style="border: none; background: #f0f0f0; padding: 0 15px; cursor: pointer; font-weight: bold;">-</button>
                        <input type="number" id="detail-qty" value="1" min="1" max="{{ producto.cantidad }}" style="width: 50px; text-align: center; border: none; font-size: 1rem; -moz-appearance: textfield;">
                        <button onclick="changeDetailQty(1)" style="border: none; background: #f0f0f0; padding: 0 15px; cursor: pointer; font-weight: bold;">+</button>
                    </div>
                    <button class="btn-primary" style="flex: 1; height: 45px; display: flex; align-items: center; justify-content: center; gap: 10px;" id="add-to-cart-btn">
                        <span>🛒</span> Sumar al carrito
                    </button>
                </div>
                {% endif %}

                <button class="btn-secondary" style="margin-top: 0.5rem; padding: 0.8rem; border: 1px solid var(--primary-color); background: transparent; color: var(--primary-color); border-radius: 8px; cursor: pointer; font-weight: 600;" onclick="location.href='/contacto'">Consultar por este producto</button>
            </div>
        </div>
    </div>
</div>

<script>
function changeDetailQty(delta) {
    const input = document.getElementById('detail-qty');
    if (!input) return;
    let val = parseInt(input.value) + delta;
    if (val < 1) val = 1;
    const max = parseInt(input.getAttribute('max'));
    if (val > max) val = max;
    input.value = val;
}

document.getElementById('add-to-cart-btn')?.addEventListener('click', () => {
    const qty = parseInt(document.getElementById('detail-qty').value);
    const product = {
        id: {{ producto.id }},
        nombre: "{{ producto.nombre }}",
        precio: {{ producto.precio or 0 }},
        imagen: "{{ imagenesOrdenadas[0].url if imagenesOrdenadas.length > 0 else '' }}",
        codigo: "{{ producto.codigo }}",
        stock: {{ producto.cantidad }}
    };
    Cart.add(product, qty);
    
    // Feedback visual
    const btn = document.getElementById('add-to-cart-btn');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span>✅</span> Agregado!';
    btn.style.background = '#2e7d32';
    setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
    }, 2000);
});
function showImage(url, thumb) {
    document.getElementById('main-product-image').src = url;
    // Reset borders
    const thumbs = thumb.parentElement.querySelectorAll('img');
    thumbs.forEach(t => t.style.borderColor = 'transparent');
    // Highlight active
    thumb.style.borderColor = 'var(--accent-color)';
}
</script>

<style>
@media (max-width: 768px) {
    .grid-detail {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }
}
</style>
{% endblock %}
